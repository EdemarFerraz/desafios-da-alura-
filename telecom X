      "cell_type": "code",
      "source": [
        " import pandas as pd\n",
        "import numpy as np\n",
        "import json\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# 1. EXTRAÇÃO E TRATAMENTO (ETL)\n",
        "with open('TelecomX_Data.json', 'r') as f:\n",
        "    data = json.load(f)\n",
        "\n",
        "df = pd.json_normalize(data, sep='_')\n",
        "\n",
        "df['account_Charges_Total'] = pd.to_numeric(df['account_Charges_Total'], errors='coerce')\n",
        "df['account_Charges_Total'] = df['account_Charges_Total'].fillna(0)\n",
        "df = df.drop_duplicates(subset=['customerID'])\n",
        "\n",
        "cols_servicos = [\n",
        "    'internet_OnlineSecurity', 'internet_OnlineBackup',\n",
        "    'internet_DeviceProtection', 'internet_TechSupport',\n",
        "    'internet_StreamingTV', 'internet_StreamingMovies'\n",
        "]\n",
        "for col in cols_servicos:\n",
        "    df[col] = df[col].replace('No internet service', 'No')\n",
        "\n",
        "# 2. ENGENHARIA DE DADOS E PADRONIZAÇÃO\n",
        "df['Contas_Diarias'] = (df['account_Charges_Monthly'] / 30).round(2)\n",
        "\n",
        "traducao_colunas = {\n",
        "    'customerID': 'ID_Cliente',\n",
        "    'Churn': 'Evasao',\n",
        "    'customer_gender': 'Genero',\n",
        "    'customer_SeniorCitizen': 'Idoso',\n",
        "    'customer_Partner': 'Tem_Parceiro',\n",
        "    'customer_Dependents': 'Tem_Dependentes',\n",
        "    'customer_tenure': 'Meses_Contrato',\n",
        "    'phone_PhoneService': 'Servico_Telefone',\n",
        "    'account_Contract': 'Tipo_Contrato',\n",
        "    'account_Charges_Monthly': 'Mensalidade',\n",
        "    'account_Charges_Total': 'Total_Gasto',\n",
        "    'account_PaymentMethod': 'Metodo_Pagamento'\n",
        "}\n",
        "df = df.rename(columns=traducao_colunas)\n",
        "\n",
        "mapeamento_binario = {'Yes': 1, 'No': 0, 'Female': 1, 'Male': 0}\n",
        "colunas_bin = ['Evasao', 'Tem_Parceiro', 'Tem_Dependentes', 'Servico_Telefone']\n",
        "for col in colunas_bin:\n",
        "    if col in df.columns:\n",
        "        df[col] = df[col].map(mapeamento_binario)\n",
        "\n",
        "df['Tipo_Contrato'] = df['Tipo_Contrato'].replace({\n",
        "    'Month-to-month': 'Mensal',\n",
        "    'One year': 'Anual',\n",
        "    'Two year': 'Bienal'\n",
        "})\n",
        "\n",
        "# 3. ANÁLISE EXPLORATÓRIA VISUAL (EDA)\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "plt.figure(figsize=(18, 10))\n",
        "\n",
        "plt.subplot(2, 2, 1)\n",
        "df['Evasao'].value_counts().plot.pie(autopct='%1.1f%%', colors=['#21918c', '#440154'], explode=[0, 0.1])\n",
        "plt.title('Proporção Geral de Evasão (Churn)')\n",
        "\n",
        "plt.subplot(2, 2, 2)\n",
        "sns.barplot(x='Tipo_Contrato', y='Evasao', data=df, palette='viridis', errorbar=None)\n",
        "plt.title('Taxa de Evasão por Tipo de Contrato')\n",
        "\n",
        "plt.subplot(2, 2, 3)\n",
        "sns.kdeplot(df[df['Evasao'] == 0]['Mensalidade'], label='Ficou', fill=True)\n",
        "sns.kdeplot(df[df['Evasao'] == 1]['Mensalidade'], label='Saiu', fill=True)\n",
        "plt.title('Distribuição de Mensalidade: Quem fica vs Quem sai')\n",
        "plt.legend()\n",
        "\n",
        "plt.subplot(2, 2, 4)\n",
        "sns.boxplot(x='Evasao', y='Meses_Contrato', data=df, palette='magma')\n",
        "plt.title('Meses de Contrato vs Evasão')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
